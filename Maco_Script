local MainTab = Window:CreateTab("Speed/Fly", 4483362458)

local Players = game:GetService("Players")
local player = Players.LocalPlayer

local normalSpeed = 16
local fastSpeed = 50

local speedEnabled = false

MainTab:CreateToggle({
   Name = "Speed Toggle",
   CurrentValue = false,
   Callback = function(Value)
      speedEnabled = Value

      local character = player.Character or player.CharacterAdded:Wait()
      local humanoid = character:WaitForChild("Humanoid")

      if speedEnabled then
         humanoid.WalkSpeed = fastSpeed
      else
         humanoid.WalkSpeed = normalSpeed
      end
   end,
})

local MiscTab = Window:CreateTab("Misc", 4483362458)

local startTime = tick()

local PlaytimeLabel = MiscTab:CreateLabel("Playtime: 0h 0m")

task.spawn(function()
   while true do
      local elapsed = tick() - startTime

      local hours = math.floor(elapsed / 3600)
      local minutes = math.floor((elapsed % 3600) / 60)

      local text = "Playtime: " .. hours .. "h " .. minutes .. "m"

      -- safer update method
      PlaytimeLabel:Set(text)

      task.wait(5) -- important: hindi 1 min, para di mag spam
   end
end)

